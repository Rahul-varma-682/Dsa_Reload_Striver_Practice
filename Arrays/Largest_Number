find the largest numbner in the Given array or any array 
input  n= [2456729]   output= 9
import java.util.*;

public class Second_largest {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        int[] a = new int[n];

        for (int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }

        int largest = a[0];
        int secondLargest = -1; 


        for (int i = 1; i < n; i++) {

            if (a[i] > largest) {
                secondLargest = largest;
                largest = a[i];
            }

            else if (a[i] < largest && a[i] > secondLargest) {
                secondLargest = a[i];
            }
        }

        System.out.println("Largest: " + largest);
        System.out.println("Second Largest: " + secondLargest);
    }
}
